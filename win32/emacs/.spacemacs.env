        return 1;
    fi;
ORIGINAL_PATH='/mingw64/bin:/usr/bin:/c/Users/maxus/bin:/d/Python310/Scripts:/d/Python310:/c/Windows/system32:/c/Windows:/c/Windows/System32/Wbem:/c/Windows/System32/WindowsPowerShell/v1.0:/c/Windows/System32/OpenSSH:/c/Program Files/NVIDIA Corporation/NVIDIA NvDLISR:/c/Program Files (x86)/NVIDIA Corporation/PhysX/Common:/c/Program Files (x86)/Vim/vim82:/c/msys64/mingw64/bin:/c/Program Files/nodejs:/c/ProgramData/chocolatey/bin:/c/texlive/2021/bin/win32:/c/Program Files/Oracle/VirtualBox:/c/Program Files/Java/jre1.8.0_311/bin:/c/Program Files/Java/java-se-8u41-ri/bin:/c/texlive/2021/bin/win32:/c/Program Files/dotnet:/c/Program Files (x86)/Microsoft VS Code:/d/Microsoft VS Code/bin:/c/tools/neovim/Neovim/bin:/d/Julia/bin:/cmd:/c/Program Files (x86)/nvim/bin:/c/Users/maxus/.cargo/bin:/c/Users/maxus/AppData/Local/Microsoft/WindowsApps:/c/Program Files (x86)/Steam:/c/Users/maxus/AppData/Roaming/npm:/c/Program Files/Mozilla Firefox:/c/Program Files (x86)/Vivaldi/Application:/:/c/Users/maxus/AppData/Local/GitHubDesktop/bin:/c/Users/maxus/.bin:/c/msys64:/c/Users/maxus/.dotnet/tools:/d/bin:/c/Users/maxus/AppData/Local/atom-nightly/bin:/c/Users/maxus/AppData/Local/atom-nightly/bin:/c/Windows/Microsoft.NET/Framework/v4.0.30319:/usr/bin:/c/Program Files/GIMP/bin:/d/VBox:/c/Program Files/VideoLAN/VLC:/d/dev/drjeff16/cbin:/d/dev/drjeff16/scripts'
        if [[ $# -eq 0 ]]; then

ORIGINAL_TMP=C:/Users/maxus/AppData/Local/Temp
                for i in ${ARG_ARR[@]};
                do
                    case "$i" in 
                        "-l" | "--no-list")
OS=Windows_NT
                        ;;
                        *[Ll][Ii][Nn][Uu][Xx]* | [Ll][Ii][Nn]* | [Gg][Nn][Uu]* | "$DWD_LINUX")
OSTYPE=msys
                        ;;
                        [Ii][Nn][Ss]* | *[Ii][Nn][Ss][Tt][Aa][Ll][Ll][Ee][Rr][Ss]* | "$DWD_I")
OneDrive='C:\Users\maxus\OneDrive'
                        ;;
                        *[Ff][Oo][Nn][Tt][Ss]* | [Tt][Tt][Ff]* | [Ww][Oo][Ff][Ff]* | "$DWD_F")
OneDriveConsumer='C:\Users\maxus\OneDrive'
                        ;;
                        *[Vv][Ii][Dd][Ee][Oo][Ss]* | *[Vv][Ii][Dd][Ss]* | *[Mm][Pp]4* | "$DWD_V")
PAGER=less
                        ;;
                        *[Aa][Pp][Pp]* | "$DWD_APPS")
PATH='/c/Users/maxus/bin:/mingw64/bin:/usr/local/bin:/usr/bin:/usr/bin:/mingw64/bin:/usr/bin:/c/Users/maxus/bin:/d/Python310/Scripts:/d/Python310:/c/Windows/system32:/c/Windows:/c/Windows/System32/Wbem:/c/Windows/System32/WindowsPowerShell/v1.0:/c/Windows/System32/OpenSSH:/c/Program Files/NVIDIA Corporation/NVIDIA NvDLISR:/c/Program Files (x86)/NVIDIA Corporation/PhysX/Common:/c/Program Files (x86)/Vim/vim82:/c/msys64/mingw64/bin:/c/Program Files/nodejs:/c/ProgramData/chocolatey/bin:/c/texlive/2021/bin/win32:/c/Program Files/Oracle/VirtualBox:/c/Program Files/Java/jre1.8.0_311/bin:/c/Program Files/Java/java-se-8u41-ri/bin:/c/texlive/2021/bin/win32:/c/Program Files/dotnet:/c/Program Files (x86)/Microsoft VS Code:/d/Microsoft VS Code/bin:/c/tools/neovim/Neovim/bin:/d/Julia/bin:/cmd:/c/Program Files (x86)/nvim/bin:/c/Users/maxus/.cargo/bin:/c/Users/maxus/AppData/Local/Microsoft/WindowsApps:/c/Program Files (x86)/Steam:/c/Users/maxus/AppData/Roaming/npm:/c/Program Files/Mozilla Firefox:/c/Program Files (x86)/Vivaldi/Application:/:/c/Users/maxus/AppData/Local/GitHubDesktop/bin:/c/Users/maxus/.bin:/c/msys64:/c/Users/maxus/.dotnet/tools:/d/bin:/c/Users/maxus/AppData/Local/atom-nightly/bin:/c/Users/maxus/AppData/Local/atom-nightly/bin:/c/Windows/Microsoft.NET/Framework/v4.0.30319:/usr/bin:/c/Program Files/GIMP/bin:/d/VBox:/c/Program Files/VideoLAN/VLC:/d/dev/drjeff16/cbin:/d/dev/drjeff16/scripts:/usr/bin/vendor_perl:/usr/bin/core_perl'
                        ;;
                        *[Gg][Aa][Mm][Ee]* | *[Gg][Aa][Mm][Ii][Nn]* | "$DWD_G")
PATHEXT='.COM;.EXE;.BAT;.CMD;.VBS;.VBE;.JS;.JSE;.WSF;.WSH;.MSC;.PY;.PYW'
                        ;;
                        *[Mm][Oo][Dd]* | "$DWD_G_MODS")
PKG_CONFIG_PATH='C:\Program Files\Git\mingw64\lib\pkgconfig;C:\Program Files\Git\mingw64\share\pkgconfig'
                        ;;
                        *)
                            echoerr "Options:\n\t-l, --no-list\n\t"
                        ;;
                    esac;
                done;
                if [[ $NO_LIST -eq 0 ]]; then
PLINK_PROTOCOL=ssh
                else
                    pushd $DIR_TO && return 0;
                fi;
            fi;
        fi;
    else
        echoerr "You're already on Downloads!";
    fi;

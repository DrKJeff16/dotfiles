SCH_GEO=C:/Users/maxus/Documents/drjeff16/School/UNAM/S1/GeometriaAnal
SCH_LENG=C:/Users/maxus/Documents/drjeff16/School/UNAM/S1/LenguajesFyA
                        pushd $SCH_ALG;

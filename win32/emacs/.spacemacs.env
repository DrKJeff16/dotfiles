gogit () 
{ 
PPID=1
    if [[ $# -eq 0 ]]; then
        pushd $GIT_D;
PROCESSOR_ARCHITECTURE=AMD64
    fi;
    return 0
}
goprog () 
{ 
PROCESSOR_IDENTIFIER='AMD64 Family 25 Model 33 Stepping 0, AuthenticAMD'
PROCESSOR_LEVEL=25
    if [[ $# -eq 0 ]]; then
PROCESSOR_REVISION=2100
        return 1;
    else
        if [[ $# -eq 1 ]]; then
            case "$DIR" in 
                [Ss][Hh] | [Ss][Hh][Ee][Ll][Ll] | "sh/sh" | "sh/sh/")
                    [[ -d $PROGD/sh/sh ]] && pushd $PROGD/sh/sh || return 1
                ;;
                [Bb][Aa][Ss][Hh] | "sh/bash" | "sh/bash/")
                    [[ -d $PROGD/sh/bash ]] && pushd $PROGD/sh/bash || return 1
                ;;
                [Zz][Ss][Hh] | [Zz][Ss][Hh][Ee][Ll][Ll] | "sh/zsh" | "sh/zsh/")
                    [[ -d $PROGD/sh/zsh ]] && pushd $PROGD/sh/zsh || return 1
                ;;
                [Pp][Yy] | [Pp][Yy]3 | [Pp][Yy][Tt][Hh][Oo][Nn] | [Pp][Yy][Tt][Hh][Oo][Nn]3 | "Python" | "Python/")
                    [[ -d $PROGD/Python ]] && pushd $PROGD/Python || return 1
                ;;
                [Rr][Bb] | [Ee][Rr][Bb] | [Rr][Uu][Bb][Yy] | "Ruby" | "Ruby/")
                    [[ -d $PROGD/Ruby ]] && pushd $PROGD/Ruby || return 1
                ;;
                [Rr][Ss] | [Rr][Uu][Ss][Tt] | [Rr][Uu][Ss][Tt][Uu][Pp] | [Cc][Aa][Rr][Gg][Oo] | "Rust" | "Rust/")
                    [[ -d $PROGD/Rust ]] && pushd $PROGD/Rust || return 1
                ;;
                [Hh][Tt][Mm][Ll] | [Ww][Ee][Bb] | [Ww][Ww][Ww] | "HTML/HTML" | "HTML/HTML/")
                    [[ -d $PROGD/HTML/HTML ]] && pushd $PROGD/HTML/HTML || return 1
                ;;
                [Cc][Ss][Ss] | [Ll][Ee][Ss][Ss] | [Ss][Cc][Ss][Ss] | "HTML/CSS" | "HTML/CSS/")
                    [[ -d $PROGD/HTML/CSS ]] && pushd $PROGD/HTML/CSS
                ;;
                [Jj][Ss] | [Jj][Aa][Vv][Aa][Ss][Cc][Rr][Ii][Pp][Tt] | "JS" | "JS/JS" | "JS/JS/" | "JS/")
                    [[ -d $PROGD/JS ]] && pushd $PROGD/JS || return 1
                ;;
                [Nn][Oo][Dd][Ee] | [Nn][Oo][Dd][Ee][Jj][Ss] | [Nn][Pp][Mm] | "JS/Node" | "JS/Node/")
                    [[ -d $PROGD/JS/Node ]] && pushd $PROGD/JS/Node || return 1
                ;;
                [Jj][Ss][Oo][Nn] | "JSON" | "JSON/")
                    [[ -d $PROGD/JSON ]] && pushd $PROGD/JSON || return 1
                ;;
                [Tt][Ss] | [Tt][Ss][Cc] | [Tt][Yy][Pp][Ee][Ss][Cc][Rr][Ii][Pp][Tt] | "JS/TS" | "JS/TS/")
                    [[ -d $PROGD/JS/TS ]] && pushd $PROGD/JS/TS || return 1
                ;;
                [Jj][Vv] | [Jj][Aa][Vv][Aa] | [Jj][Rr][Ee] | [Jj][Dd][Kk] | "Java" | "Java/")
                    [[ -d $PROGD/Java ]] && pushd $PROGD/Java || return 1
                ;;
                [Cc] | [Gg][Cc][Cc] | "C/C" | "C/C/")
                    [[ -d $PROGD/C/C ]] && pushd $PROGD/C/C || return 1
                ;;
                [Cc][Pp][Pp] | [Cc]\+\+ | [Gg]\+\+ | "C/C++" | "C/C++/")
                    [[ -d $PROGD/C/C\+\+ ]] && pushd $PROGD/C/C\+\+ || return 1
                ;;
                [Cc][Ss] | [Cc][Ss][Hh][Aa][Rr][Pp] | [Cc]\# | [Mm][Oo][Nn][Oo] | \.[Nn][Ee][Tt] | "C/C#" | "C/C#/")
                    [[ -d $PROGD/C/C\# ]] && pushd $PROGD/C/C\# || return 1
                ;;
                [Tt][Ee][Xx] | [Ll][Aa][Tt][Ee][Xx] | [Bb][Ii][Bb][Tt][Ee][Xx] | [Pp][Dd][Ff] | "LaTeX" | "LaTeX/")
                    [[ -d $PROGD/LaTeX ]] && pushd $PROGD/LaTeX || return 1
                ;;
                [Gg][Oo] | [Gg][Oo][Ll][Aa][Nn][Gg] | "Go" | "Go/")
                    [[ -d $PROGD/Go ]] && pushd $PROGD/Go || return 1
                ;;
                [Aa][Ss][Mm] | [Aa][Ss][Ss][Ee][Mm][Bb][Ll][Yy] | [Aa][Ss][Ss][Ee][Mm][Bb][Ll][Ee][Rr] | "Assembly" | "Assembly/")
                    [[ -d $PROGD/Assembly ]] && pushd $PROGD/Assembly || return 1
                ;;
                [Xx]86[Aa][Ss][Mm] | "Assembly/x86ASM" | "Assembly/x86ASM/")
                    [[ -d $PROGD/Assembly/x86ASM ]] && pushd $PROGD/Assembly/x86ASM || return 1
                ;;
                [Mm][Dd] | [Mm][Aa][Rr][Kk][Dd][Oo][Ww][Nn] | "Markdown" | "Markdown/")
                    [[ -d $PROGD/Markdown ]] && pushd $PROGD/Markdown || return 1
                ;;
                *)
                    echoerr "Can't find that directory." "Aborting!" && return 1
                ;;
            esac;
        fi;
    fi;
PROGRAMFILES='C:\Program Files'
    return 0
}

#!/usr/bin/env bash

set -o pipefail

OPTIONS=':hfclF:'
CONFIGURED=0
CONFIGURE_ONLY=0
FORCE=0
FORTIFY=0
LTO=0

COMPILE_LOG="${HOME}/.cache/vim_compile.log"
CURR_DIR="$(pwd)"
NPROC="$(nproc)"
TARGET_PFX="/usr/local"

export CC='gcc' CXX='g++' CFLAGS="-O2 -g -march=native -pipe -D_GNU_SOURCE -DNDEBUG -D_DEFAULT_SOURCE"

VIMRT="${TARGET_PFX}/share/vim/vim91"
DATAROOTDIR="${TARGET_PFX}/share"
DOC_D="${DATAROOTDIR}/doc"
INFO_D="${DATAROOTDIR}/info"
MAN_D="${DATAROOTDIR}/man"
MAKECMD="make -j${NPROC} -l$((NPROC + 1)) VIMRUNTIMEDIR=${VIMRT}"

error() {
    local TXT=("$@")
    printf "%s\n" "${TXT[@]}" >&2
    return 0
}

_cmd() {
    [[ $# -eq 0 ]] && return 127

    while [[ $# -gt 0 ]]; do
        ! command -v "$1" &> /dev/null && return 1
        shift
    done

    return 0
}

die() {
    local EC=0
    local POPPED_D=0

    # In case a chdir operation occured
    while [[ "$(pwd)" == "${HOME}/.build/vim/"* ]]; do
        if [[ $POPPED_D -eq 0 ]]; then
            popd &> /dev/null || POPPED_D=1
        else
            cd .. || exit 4
        fi
    done

    if [[ $# -gt 0 ]] && [[ $1 =~ ^(0|-?[1-9][0-9]*)$ ]]; then
        EC="$1"
        shift
    fi

    if [[ $# -gt 0 ]]; then
        local TXT=("$@")
        if [[ $EC -eq 0 ]]; then
            printf "%s\n" "${TXT[@]}"
        else
            error "${TXT[@]}"
        fi
    fi

    exit "${EC}"
}

usage() {
    local EC=0
    [[ "$1" =~ ^(0|-?[1-9][0-9]*)$ ]] && EC="$1"

    local TXT=(
        "build_nvim: A boring neovim build script."
        ""
        "  usage:   build_nvim [-h] [-f] [-c] [-l] [-F 1|2|3]"
        ""
        "     -h                       Prints this help message (exit code: 0)"
        ""
        ""
        "     -F 1|2|3                 Sets \`-D_FORTIFY_SOURCE\` level"
        ""
        "     -c                       Only trigger \`configure\` stage"
        ""
        "     -f                       Skip validation for CWD, attempt to build regardless"
        ""
        "     -l                       Enable Link Time Optimization"
        ""
    )

    die "${EC}" "${TXT[@]}"
}

if ! _cmd 'yn'; then
    function yn() {
        local PROMPT="Continue?"
        [[ $# -gt 0 ]] && PROMPT="$1"

        while true; do
            local ANS
            read -rp "${PROMPT} [Y/n]: " ANS

            case "$ANS" in
                [Yy] | "") return 0 ;;
                [Nn]) return 1 ;;
                *) continue ;;
            esac
        done

        return 1
    }
fi

_pull() {
    [[ $FORCE -eq 1 ]] && echo -n >| "${COMPILE_LOG}" && return 0

    git pull --rebase | tee "${COMPILE_LOG}" || die 2 "\`git pull --rebase\` failed"

    if [[ "$(cat "${COMPILE_LOG}")" == *"Already up to date"* ]] && ! yn "Up to date. Continue?"; then
        die 0
    fi

    return 0
}

_configure() {
    ./configure \
        --datarootdir="${DATAROOTDIR}" \
        --disable-arabic \
        --disable-darwin \
        --disable-farsi \
        --disable-gnome-check \
        --disable-gtk2-check \
        --disable-gtktest \
        --disable-motif-check \
        --disable-rightleft \
        --disable-selinux \
        --docdir="${DOC_D}" \
        --enable-cscope \
        --enable-fail-if-missing \
        --enable-fontset \
        --enable-gtk3-check \
        --enable-gui='gtk3' \
        --enable-luainterp=dynamic \
        --enable-multibyte \
        --enable-perlinterp=dynamic \
        --enable-python3interp=dynamic \
        --enable-rubyinterp=dynamic \
        --enable-socketserver \
        --enable-tclinterp=dynamic \
        --enable-terminal \
        --enable-wayland-focus-steal \
        --enable-year2038 \
        --infodir="${INFO_D}" \
        --mandir="${MAN_D}" \
        --prefix="${TARGET_PFX}" \
        --prefix=/usr/local \
        --sysconfdir="/etc" \
        --with-features=huge \
        --with-lua-prefix=/usr \
        --with-luajit \
        --with-python3-config-dir="$(python3-config --configdir)" \
        --with-wayland \
        --without-gnome \
        --without-x \
        --with-compiledby='DrKJeff16' \
        VIMRUNTIMEDIR="${VIMRT}"

    CONFIGURED=1

    return $?
}

_verify_configured() {
    if [[ $CONFIGURED -ne 1 ]] || ! [[ -f ./auto/config.mk ]]; then
        return 1
    fi

    CONFIGURED=1
    return 0
}

_drop_fortify() {
    ! _verify_configured && die 1 "Is this even configured?"

    if [[ "$FORTIFY" =~ ^[1-3]$ ]]; then
        ! sed -i "s/\s-D_FORTIFY_SOURCE=[0-9]/ -D_FORTIFY_SOURCE=${FORTIFY}/g" ./auto/config.mk \
            && die 6 "ERROR when trying to run \`sed\`"

    else
        ! sed -i 's/\s-D_FORTIFY_SOURCE=[0-9]//g' ./auto/config.mk \
            && die 6 "ERROR when trying to run \`sed\`"

    fi

    return 0
}

! _cmd 'make' 'git' && die 127 "Either \`make\` or \`git\` not found in PATH"

[[ "$(basename "$CURR_DIR")" != "src" ]] && die 127 "Not in \`src/\` directory"

! [[ -d ../.git ]] && die 127 "Not in \`src/\` directory"
! [[ -x ./configure ]] && die 127 "No \`./configure\` executable"

while getopts "$OPTIONS" OPTION; do
    case "$OPTION" in
        F) FORTIFY="${OPTARG}" ;;
        c) CONFIGURE_ONLY=1 ;;
        f) FORCE=1 ;;
        l) LTO=1 ;;
        h) usage 0 ;;
        *) usage 1 ;;
    esac
done

[[ $LTO -eq 1 ]] && CFLAGS+=" -flto"

_pull

eval "${MAKECMD} distclean" || die 1 \"\`make distclean\` failed\"

_configure
_drop_fortify
EC=$?

[[ $CONFIGURE_ONLY -eq 1 ]] && die "$EC"

eval "${MAKECMD}" || die 1 "Compilation failed"
eval "sudo ${MAKECMD} install" || die 1 "Installation failed"

eval "${MAKECMD} distclean" || die 1

git restore --staged ../. || die 1
git restore ../. || die 1

die 0

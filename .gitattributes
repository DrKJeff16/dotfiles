# Common settings that generally should always be used with your language specific settings

# Auto detect text files and perform LF normalization
*          text=auto

#
# The above will handle all files NOT found below
#

# Lua
*.lua      text eol=lf

# Documents
*.DOC      diff=astextplain
*.DOCX     diff=astextplain
*.DOT      diff=astextplain
*.PDF      diff=astextplain
*.RTF      diff=astextplain
*.adoc     text
*.bibtex   text diff=bibtex
*.csv      text eol=lf
*.doc      diff=astextplain
*.docx     diff=astextplain
*.dot      diff=astextplain
*.epub     diff=astextplain
*.md       text diff=markdown eol=lf
*.mdx      text diff=markdown eol=lf
*.mustache text
*.pdf      diff=astextplain
*.rtf      diff=astextplain
*.sql      text eol=lf
*.tab      text
*.tex      text diff=tex eol=lf
*.textile  text eol=lf
*.tsv      text
*.txt      text eol=lf

# Graphics
*.eps      binary
*.gif      binary
*.ico      binary
*.jpeg     binary
*.jpg      binary
*.png      binary
*.svg      text
*.tif      binary
*.tiff     binary

# Binary
*.db     binary
*.p      binary
*.pickle binary
*.pkl    binary
*.pyc    binary export-ignore
*.pyd    binary
*.pyo    binary export-ignore

# Scripts
*.bash     text eol=lf
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.fish     text eol=lf
*.ksh      text eol=lf
*.ps1      text eol=crlf
*.sh       text eol=lf
*.zsh      text eol=lf

# Serialisation
*.json     text eol=lf
*.toml     text eol=lf
*.xml      text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf

# Archives
*.7z       binary
*.Z        binary
*.bz       binary
*.bz2      binary
*.bzip2    binary
*.gz       binary
*.lz       binary
*.lzma     binary
*.rar      binary
*.tar      binary
*.taz      binary
*.tbz      binary
*.tbz2     binary
*.tgz      binary
*.tlz      binary
*.txz      binary
*.xz       binary
*.zip      binary
*.zst      binary

# Text files where line endings should be preserved
*.patch    -text

#
# Exclude files from exporting
#

.gitattributes export-ignore
.gitignore     export-ignore
.gitkeep       export-ignore

# Basic .gitattributes for a python repo.

# Python
*.pxd    text diff=python eol=lf
*.py     text diff=python eol=lf
*.py3    text diff=python eol=lf
*.pyi    text diff=python eol=lf
*.pyw    text diff=python eol=lf
*.pyx    text diff=python eol=lf
*.pyz    text diff=python eol=lf

# Jupyter notebook
*.ipynb  text eol=lf

# Vim
*.vim   text eol=lf
.gvimrc text eol=lf
.vimrc  text eol=lf
gvimrc  text eol=lf
vimrc   text eol=lf
